# ──────────────────────────────────────────────────────────────────────────
# Financial QA Chatbot — environment configuration
# Copy to `.env` and fill in the blanks.
# ──────────────────────────────────────────────────────────────────────────

# Chat LLM (OpenAI-compatible endpoint)
BASE_URL=https://api.openai.com/v1
API_KEY=
MODEL_NAME=gpt-4o-mini

# Embeddings — MUST produce 512-dim vectors compatible with the provided
# fixture (data/pinecone_vectors.jsonl.gz was built with text-embedding-3-small
# at dimensions=512). Point this at OpenAI or a 1:1 proxy to that exact model,
# otherwise cosine retrieval against the fixture breaks.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIM=512

# Langfuse (cloud). The app runs fully with this disabled.
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# PostgreSQL (async driver for the app; sync URL derived for Alembic/loaders)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/financial_qa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=financial_qa

# Pinecone Local (docker image pinecone-local)
PINECONE_API_KEY=pclocal
PINECONE_HOST=http://pinecone-local:5080
PINECONE_INDEX_NAME=tenk-filings
PINECONE_NAMESPACE=__default__

# Auth / JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=demo1234

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# Frontend (Next.js) — base URL of the backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
